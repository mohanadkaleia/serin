# msg deployment secrets (ENG-72). Copy to .env and fill in — .env is gitignored,
# never commit real secrets. Only placeholders live here.
#
#   cp .env.example .env
#
# Postgres superuser password for the `msg` role. Used by both services
# (the app's MSG_DATABASE_URL and the postgres container init).
POSTGRES_PASSWORD=

# Application secret (session-token / signing material). Generate a strong value:
#   openssl rand -hex 32
MSG_SECRET_KEY=

# Optional. Log verbosity (DEBUG | INFO | WARNING | ERROR). Defaults to INFO.
MSG_LOG_LEVEL=INFO
